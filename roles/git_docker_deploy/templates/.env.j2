# ---- Host ports (published) ----
APP_PORT={{ app_port }}
POSTGRES_PORT=5433
PUBLIC_BASE_PATH=/
VITE_API_URL=/api
ADMIN_API_KEY=123!@#qweQWE

# ---- TLS (backend HTTPS) ----
TLS_ENABLED=false
TLS_KEY_PATH=/run/tls/tls.key
TLS_CERT_PATH=/run/tls/tls.crt
TLS_CA_PATH=
TLS_PASSPHRASE=

# ---- Backend healthcheck behavior ----
HEALTHCHECK_ENABLED=true
HEALTHCHECK_RUN_ONCE=true
HEALTHCHECK_MARKER_PATH=/tmp/.backend-healthcheck-ok

# ---- Postgres (container) ----
POSTGRES_DB=profit_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=123!@#qweQWE

# ---- Backend (host defaults; compose overrides DB_HOST/DB_PORT) ----
NODE_ENV=production
# Важно: внутри docker контейнер backend слушает `PORT` (по умолчанию 3000). Снаружи используем `APP_PORT`.
PORT=3000
CORS_ORIGIN=http://localhost:5173

DB_HOST=localhost
DB_PORT=5433
DB_NAME=profit_db
DB_USER=postgres
DB_PASSWORD=123!@#qweQWE

DATABASE_URL=postgresql://postgres:123!@#qweQWE@localhost:5433/profit_db
